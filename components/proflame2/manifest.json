{
  "domain": "proflame2",
  "name": "ProFlame 2 Fireplace Control",
  "documentation": "https://github.com/dangerouslaser/proflame2-esp",
  "dependencies": ["spi","switch","number","light","fan", "button","binary_sensor"],
  "codeowners": ["@dangerouslaser","@marksieczkowski","@j2deen"],
  "requirements": [],
  "version": "4.0.0",
  "author": "Bryan Hoban, Mark Sieczkowski, Jay Deen",
  "license": "MIT",
  "description": "Control ProFlame 2 fireplace systems using ESP32 (or LilyGo T-Embed CC1101) and a CC1101 RF module",
  "hardware": {
    "supported": ["ESP32", "ESP32-S3", "LilyGo T-Embed CC1101"],
    "required": ["CC1101 RF Module (315 MHz tunable)"]
  },
  "features": [
    "Power on/off control",
    "Flame height adjustment (0-6 levels)",
    "Fan speed control (0-6 levels)",
    "Light level control (0-6 levels)",
    "Secondary flame control",
    "IPI/CPI pilot mode selection",
    "Auxiliary power control",
    "HEAT/OFF climate (thermostat) entity with HA temperature sensor",
    "Persistent heat-mode config entities (flame/fan/secondary)",
    "On-device LCD + rotary encoder UI (T-Embed CC1101)",
    "On-device learn-mode pairing (recovers serial + ECC from OEM remote)",
    "Home Assistant integration",
    "Web interface",
    "MQTT support",
    "Send buffered commands"
  ],
  "config_schema": {
    "cs_pin": "required",
    "gdo0_pin": "optional",
    "serial_number": "required",
    "power": "optional",
    "pilot": "optional",
    "aux": "optional",
    "flame": "optional",
    "fan": "optional",
    "light": "optional",
    "secondary_flame": "optional",
    "send": "optional"
  }
}
